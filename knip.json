{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "backend": {
      "entry": ["src/cron/*/index.ts", "scripts/*.js", "src/**/*.test.ts", "scripts/*.test.js"],
      "project": ["src/**/*.ts", "scripts/**/*.js"]
    },
    "frontend": {
      "entry": ["index.html"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "playwright": {
      "entry": ["*.spec.ts"],
      "project": ["**/*.ts"]
    }
  }
}
