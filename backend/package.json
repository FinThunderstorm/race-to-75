{
  "name": "race-to-75-backend",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "db:migrate": "node scripts/migrate.js",
    "auth:bootstrap-admin": "node scripts/bootstrap-admin.js",
    "build": "tsc",
    "cron:fetch-withings-measurement": "node dist/cron/fetch-withings-measurement/index.js",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/auth": "5.0.4",
    "@fastify/cookie": "11.0.2",
    "@fastify/jwt": "10.1.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/static": "9.1.3",
    "@simplewebauthn/server": "13.3.2",
    "fastify": "5.8.5",
    "fastify-plugin": "6.0.0",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
